DB_HOST=localhost
DB_NAME=pdf_store
DB_USER=root
DB_PASS=

APP_ENV=development

# Public base URL (no trailing slash, must include /public if applicable)
BASE_URL=http://localhost/public

# Maximum upload size in bytes (default 5 MB)
UPLOAD_MAX_SIZE=5000000

# Hours before an uploaded document is auto-deactivated
AUTO_DELETE_HOURS=12

# BCrypt cost factor for password hashing (10-14 recommended; higher = slower + safer)
BCRYPT_COST=12

# Set to true when running behind a reverse proxy (Nginx, Cloudflare, etc.)
# Enables X-Forwarded-Proto and X-Forwarded-For trust
TRUST_PROXY=false
