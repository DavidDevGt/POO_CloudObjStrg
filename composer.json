{
    "require": {
        "php": "^8.1",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "mockery/mockery": "^1.6",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-strict-rules": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.68"
    },
    "autoload": {
        "psr-4": {
            "Config\\":     "config/",
            "Models\\":     "models/",
            "Contracts\\": "contracts/",
            "Storage\\":    "storage/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test":             "phpunit",
        "test:unit":        "phpunit --testsuite Unit",
        "test:smoke":       "phpunit --testsuite Smoke",
        "test:integration": "phpunit --testsuite Integration",
        "migrate":          "php migrations/migrate_data.php",
        "analyse":          "phpstan analyse --memory-limit=256M",
        "cs:check":         "php-cs-fixer check --diff --allow-risky=yes",
        "cs:fix":           "php-cs-fixer fix --allow-risky=yes"
    }
}
