# Deny access to everything except static assets routed through index.php.
Options -Indexes -MultiViews

# Security headers
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

# Block access to hidden files/directories (.git, .env, etc.)
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# Block access to composer files and sensitive directories
<FilesMatch "(composer\.(json|lock)|phpunit\.xml)$">
    Require all denied
</FilesMatch>

# Disable server signature
ServerSignature Off
